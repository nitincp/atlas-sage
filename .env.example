# ── ATLAS-SAGE environment configuration ──────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# Both ATLAS_TIER1_MODEL and ATLAS_TIER2_MODEL are required.
#
# LiteLLM model string format: "<provider>/<model-name>"
# Provider is encoded in the string — no provider-specific code needed.

# ── Option A: Ollama (fully local, no API key) ────────────────────────────────
ATLAS_TIER1_MODEL=ollama/llama3.2
ATLAS_TIER2_MODEL=ollama/llama3.1:8b
ATLAS_OLLAMA_BASE=http://localhost:11434

# ── Option B: Claude API ──────────────────────────────────────────────────────
# ATLAS_TIER1_MODEL=claude-haiku-4-5-20251001
# ATLAS_TIER2_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option C: OpenAI ──────────────────────────────────────────────────────────
# ATLAS_TIER1_MODEL=gpt-4o-mini
# ATLAS_TIER2_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Store & embeddings ────────────────────────────────────────────────────────
ATLAS_LANCEDB_PATH=.atlas_sage/db
ATLAS_EMBED_MODEL=BAAI/bge-m3

# ── Skill system ─────────────────────────────────────────────────────────────
ATLAS_SKILL_LOOP_LIMIT=5
