# ── ATLAS-SAGE environment configuration ──────────────────────────────────────
#
# Copy this file to .env and fill in values.
#
# Two model env vars drive the system:
#   ATLAS_ORCHESTRATOR_MODEL  — agent loop, routing, per-node summaries (required)
#   ATLAS_SKILL_MODEL         — one-time skill code generation per file type (optional)
#                               defaults to ATLAS_ORCHESTRATOR_MODEL if unset
#
# LiteLLM model string format: "<provider>/<model>" or "<model>" for Anthropic/OpenAI.
# Provider is encoded in the model string — no provider-specific code anywhere.

# ── Option A: Google AI (Gemini) ─────────────────────────────────────────────
ATLAS_ORCHESTRATOR_MODEL=gemini/gemini-2.5-flash
ATLAS_SKILL_MODEL=gemini/gemini-2.5-pro
GEMINI_API_KEY=...

# ── Option B: Claude API ──────────────────────────────────────────────────────
# ATLAS_ORCHESTRATOR_MODEL=claude-sonnet-4-6
# ATLAS_SKILL_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option C: Ollama (fully local — use when system has matured) ──────────────
# ATLAS_ORCHESTRATOR_MODEL=ollama/llama3.1:8b
# ATLAS_SKILL_MODEL=ollama/llama3.1:8b
# ATLAS_OLLAMA_BASE=http://localhost:11434

# ── LLM tuning (optional) ────────────────────────────────────────────────────
# ATLAS_MAX_TOKENS=8192   # max output tokens per call (default 8192)

# ── Store & embeddings ────────────────────────────────────────────────────────
ATLAS_LANCEDB_PATH=.atlas_sage/db
# Google AI (works with GEMINI_API_KEY):
ATLAS_EMBED_MODEL=gemini/gemini-embedding-001
# OpenAI alternative:
# ATLAS_EMBED_MODEL=text-embedding-3-small

# ── Skill system ──────────────────────────────────────────────────────────────
ATLAS_SKILL_LOOP_LIMIT=5

# ── Ollama (only needed when any model uses ollama/ prefix) ───────────────────
ATLAS_OLLAMA_BASE=http://localhost:11434
