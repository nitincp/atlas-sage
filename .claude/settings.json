{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pip install -r *)",
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)"
    ],
    "deny": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- See docs/BACKLOG.md for sprint status ---'"
          }
        ]
      }
    ]
  }
}
